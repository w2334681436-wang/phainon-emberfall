+    this.els.mobileAttack.textContent = building ? '放置' : driving ? '鸣笛' : '攻击';
+    this.els.mobileInteract.textContent = building ? '旋转' : driving ? '下车' : '互动';
+    this.els.mobileJump.textContent = driving ? '刹车' : '跳跃';
+    this.els.mobileReload.classList.toggle('hidden', building || driving);
+    this.els.mobileSprint.classList.toggle('hidden', building || driving);
+    this.els.mobileCancel.classList.toggle('hidden', !building);
   }
 
