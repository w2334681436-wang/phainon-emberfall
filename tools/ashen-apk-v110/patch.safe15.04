+  clearPlacedStructures() {
+    const placed = new Set(this.placedGroups);
+    for (const group of placed) this.scene.remove(group);
+    this.colliders = this.colliders.filter((c) => !placed.has(c.mesh) && !placed.has(c.parent));
+    this.interactables = this.interactables.filter((inter) => !placed.has(inter.mesh));
+    this.placedGroups = [];
+  }
+
+  isPositionBlocked(position, radius = 0.5) {
+    const half = WORLD_SIZE * 0.49;
+    if (Math.abs(position.x) > half || Math.abs(position.z) > half) return true;
+    for (const c of this.colliders) {
+      const b = c.box;
+      if (position.x > b.min.x - radius && position.x < b.max.x + radius && position.z > b.min.z - radius && position.z < b.max.z + radius) return true;
+    }
+    return false;
+  }
+
+  raycastObstacle(origin, direction, maxDistance) {
+    const ray = new THREE.Ray(origin, direction.clone().normalize());
+    const hit = new THREE.Vector3();
+    let best = maxDistance;
+    for (const c of this.colliders) {
+      if (!ray.intersectBox(c.box, hit)) continue;
+      const distance = origin.distanceTo(hit);
+      if (distance > 0.15 && distance < best) best = distance;
+    }
+    return best;
+  }
+
+  updateProximityVisibility(position) {
+    const harvestRange = this.mobile ? 230 : 430;
+    const bushRange = this.mobile ? 190 : 360;
+    const harvestSq = harvestRange * harvestRange;
+    const bushSq = bushRange * bushRange;
+    for (const h of this.harvestables) {
+      h.nearVisible = h.position.distanceToSquared(position) <= harvestSq;
+      h.mesh.visible = !h.harvested && h.nearVisible;
+    }
+    for (const inter of this.interactables) {
+      if (inter.type !== 'bush') continue;
+      inter.nearVisible = inter.position.distanceToSquared(position) <= bushSq;
+      inter.mesh.visible = inter.cooldown <= 0 && inter.nearVisible;
+    }
+  }
+
+  serializeState() {
+    return {
+      harvestables: this.harvestables.map((h) => ({ hp: h.hp, harvested: h.harvested })),
+      bushes: this.interactables.filter((i) => i.type === 'bush').map((b) => ({ cooldown: b.cooldown }))
+    };
+  }
+
+  restoreState(data) {
+    if (Array.isArray(data?.harvestables)) {
+      data.harvestables.slice(0, this.harvestables.length).forEach((entry, i) => {
+        const h = this.harvestables[i];
+        h.hp = THREE.MathUtils.clamp(Number(entry.hp) || h.maxHp, 0, h.maxHp);
+        h.harvested = Boolean(entry.harvested) || h.hp <= 0;
+        h.mesh.visible = !h.harvested && h.nearVisible;
+      });
+    }
+    const bushes = this.interactables.filter((i) => i.type === 'bush');
+    if (Array.isArray(data?.bushes)) {
+      data.bushes.slice(0, bushes.length).forEach((entry, i) => {
+        bushes[i].cooldown = Math.max(0, Number(entry.cooldown) || 0);
+        bushes[i].mesh.visible = bushes[i].cooldown <= 0 && bushes[i].nearVisible;
+      });
+    }
+  }
+
+  resetDynamicState() {
+    for (const h of this.harvestables) {
+      h.hp = h.maxHp;
+      h.harvested = false;
+      h.mesh.visible = h.nearVisible;
+    }
+    for (const b of this.interactables) {
+      if (b.type !== 'bush') continue;
+      b.cooldown = 0;
+      b.mesh.visible = b.nearVisible;
+    }
+    this.clearPlacedStructures();
+  }
+
